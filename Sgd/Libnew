function Lib:CreateWindow(title)

	local frame = Instance.new("Frame")
	frame.Size             = UDim2.new(0, WIN_W, 0, WIN_H)
	frame.Position         = UDim2.new(0.5, -WIN_W/2, 0.5, -WIN_H/2)
	frame.BackgroundColor3 = Color3.fromRGB(8,8,8)
	frame.ClipsDescendants = true
	frame.Active           = true
	frame.Visible          = false
	frame.ZIndex           = 10
	frame.Parent           = _gui
	local fCorner = Instance.new("UICorner", frame)
	fCorner.CornerRadius = UDim.new(0,12)
	local fStroke = Instance.new("UIStroke", frame)
	fStroke.Thickness = 2

	-- Faded black and white stroke
	task.spawn(function()
		local t = 0
		while frame and frame.Parent do
			t = t + 0.03
			local b = (math.sin(t) + 1) / 2
			local v = math.floor(b * 255)
			fStroke.Color = Color3.fromRGB(v,v,v)
			task.wait(0.03)
		end
	end)

	-- TITLE SECTION
