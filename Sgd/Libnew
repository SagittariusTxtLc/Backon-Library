			for _, v in ipairs(options or {}) do
				local opt = Instance.new("TextButton")
				opt.Size             = UDim2.new(1,0,0,30)
				opt.Text             = v
				opt.BackgroundColor3 = Color3.fromRGB(22,22,22)
				opt.TextColor3       = Color3.fromRGB(220,20,60)
				opt.Font             = Enum.Font.GothamBold
				opt.TextSize         = 12
				opt.ZIndex           = 13
				opt.Parent           = dropFrame
				_style(opt)
				opt.MouseButton1Click:Connect(function()
					selected = v; selLbl.Text = v; open = false
					TweenService:Create(dropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1,0,0,0)}):Play()
					task.wait(0.21)
					scroll.CanvasSize = UDim2.new(0,0,0, cLayout.AbsoluteContentSize.Y + 10)
					if callback then pcall(callback, v) end
				end)
			end
			dropBtn.MouseButton1Click:Connect(function()
				open = not open
				local h = open and (#options * 30) or 0
				TweenService:Create(dropFrame, TweenInfo.new(0.25), {Size = UDim2.new(1,0,0,h)}):Play()
				task.delay(0.26, function()
					scroll.CanvasSize = UDim2.new(0,0,0, cLayout.AbsoluteContentSize.Y + 10)
				end)
			end)
			local D = {}
			function D:Get() return selected end
			function D:Set(v) selected = v; selLbl.Text = v end
			return D
		end

		-- CLIPBOARD BUTTON
		function Folder:ClipboardButton(text, clipText)
			local btn2 = Instance.new("TextButton")
			btn2.Size             = UDim2.new(1,0,0,38)
			btn2.Text             = text or "Copy"
			btn2.BackgroundColor3 = Color3.fromRGB(18,18,18)
			btn2.TextColor3       = Color3.fromRGB(255,255,255)
			btn2.Font             = Enum.Font.GothamBold
			btn2.TextSize         = 13
			btn2.LayoutOrder      = fnxt()
			btn2.TextXAlignment   = Enum.TextXAlignment.Left
			btn2.ZIndex           = 12
			btn2.Parent           = contentFrame
			_style(btn2)
			local bp = Instance.new("UIPadding")
			bp.PaddingLeft = UDim.new(0,10); bp.Parent = btn2
			btn2.MouseButton1Click:Connect(function()
				TweenService:Create(btn2, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(45,45,45)}):Play()
				task.wait(0.1)
				TweenService:Create(btn2, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(18,18,18)}):Play()
				if clipText then pcall(function() setclipboard(clipText) end) end
			end)
			return btn2
		end

		-- SECTION
		function Folder:Section(text)
			local sec = Instance.new("Frame")
			sec.Size                  = UDim2.new(1,0,0,22)
			sec.BackgroundTransparency = 1
			sec.LayoutOrder           = fnxt()
			sec.Parent                = contentFrame
			local line = Instance.new("Frame")
			line.Size             = UDim2.new(1,0,0,1)
			line.Position         = UDim2.new(0,0,0.5,0)
			line.BackgroundColor3 = Color3.fromRGB(35,35,35)
			line.BorderSizePixel  = 0
			line.Parent           = sec
			local sLbl = Instance.new("TextLabel")
			sLbl.Size                  = UDim2.new(0,0,1,0)
			sLbl.AutomaticSize         = Enum.AutomaticSize.X
			sLbl.Position              = UDim2.new(0.5,0,0,0)
			sLbl.AnchorPoint           = Vector2.new(0.5,0)
			sLbl.BackgroundColor3      = Color3.fromRGB(8,8,8)
			sLbl.Text                  = " " .. (text or "") .. " "
			sLbl.TextColor3            = Color3.fromRGB(120,120,120)
			sLbl.Font                  = Enum.Font.GothamBold
			sLbl.TextSize              = 11
			sLbl.ZIndex                = 13
			sLbl.Parent                = sec
		end

		return Folder
	end

	return Win
end

function Lib:Start()
	_loaded = true
	if _pendingShow then _pendingShow() end
end

return Lib
