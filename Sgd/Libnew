local TweenService = game:GetService("TweenService")
local UIS          = game:GetService("UserInputService")
local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local player       = Players.LocalPlayer

-- ANTI-DUPE
local existingGui = player:WaitForChild("PlayerGui"):FindFirstChild("SmileyHubGui")
if existingGui then existingGui:Destroy() end
if _G.SmileyRunning then
	_G.SmileyRunning = false
	if _G.SmileyConnection then _G.SmileyConnection:Disconnect(); _G.SmileyConnection = nil end
end
