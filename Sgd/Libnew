local Lib   = {}
Lib.__index = Lib

local _gui = Instance.new("ScreenGui")
_gui.Name           = "SmileyHubGui"
_gui.ResetOnSpawn   = false
_gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
_gui.Parent         = player.PlayerGui

local _loaded      = false
local _pendingShow = nil
local WIN_W        = 260

local function _style(obj, strokeColor)
	Instance.new("UICorner", obj)
	local s = Instance.new("UIStroke", obj)
	s.Color = strokeColor or Color3.fromRGB(60,60,60)
	s.Thickness = 1
end

function Lib:CreateWindow(title)

	local frame = Instance.new("Frame")
	frame.Size             = UDim2.new(0, WIN_W, 0, 100)
	frame.Position         = UDim2.new(0.5, -WIN_W/2, 0, 10)
	frame.BackgroundColor3 = Color3.fromRGB(10,10,10)
	frame.ClipsDescendants = true
	frame.Active           = true
	frame.Visible          = false
	frame.ZIndex           = 10
	frame.Parent           = _gui
	Instance.new("UICorner", frame)
	local fStroke = Instance.new("UIStroke", frame)
	fStroke.Thickness = 2

	-- Black and white faded stroke animation
	task.spawn(function()
		local t = 0
		while frame and frame.Parent do
			t = t + 0.03
			local brightness = (math.sin(t) + 1) / 2
			fStroke.Color = Color3.fromRGB(
				math.floor(brightness * 255),
				math.floor(brightness * 255),
				math.floor(brightness * 255)
			)
			task.wait(0.03)
		end
	end)

	-- TITLE BAR
	local titleBar = Instance.new("Frame")
	titleBar.Size             = UDim2.new(1,0,0,40)
	titleBar.BackgroundColor3 = Color3.fromRGB(15,15,15)
	titleBar.BorderSizePixel  = 0
	titleBar.ZIndex           = 11
	titleBar.Active           = true
	titleBar.Parent           = frame
	Instance.new("UICorner", titleBar)

	local titleLbl = Instance.new("TextLabel")
	titleLbl.Size               = UDim2.new(1,-50,1,0)
	titleLbl.Position           = UDim2.new(0,12,0,0)
	titleLbl.Text               = "Smileyy Hub | " .. string.upper(title or "Window")
	titleLbl.Font               = Enum.Font.GothamBold
	titleLbl.TextSize           = 13
	titleLbl.TextColor3         = Color3.fromRGB(255,255,255)
	titleLbl.BackgroundTransparency = 1
	titleLbl.TextXAlignment     = Enum.TextXAlignment.Left
	titleLbl.ZIndex             = 12
	titleLbl.Parent             = titleBar

	-- COLLAPSE BUTTON
	local colBtn = Instance.new("TextButton")
	colBtn.Size               = UDim2.new(0,28,0,28)
	colBtn.Position           = UDim2.new(1,-34,0.5,-14)
	colBtn.Text               = "v"
	colBtn.BackgroundColor3   = Color3.fromRGB(25,25,25)
	colBtn.Font               = Enum.Font.GothamBold
	colBtn.TextSize           = 14
	colBtn.TextColor3         = Color3.fromRGB(255,255,255)
	colBtn.ZIndex             = 12
	colBtn.Parent             = titleBar
	Instance.new("UICorner", colBtn)

	-- TAB BAR (horizontal folder tabs)
	local tabBar = Instance.new("Frame")
	tabBar.Size             = UDim2.new(1,0,0,32)
	tabBar.Position         = UDim2.new(0,0,0,40)
	tabBar.BackgroundColor3 = Color3.fromRGB(12,12,12)
	tabBar.BorderSizePixel  = 0
	tabBar.ZIndex           = 11
	tabBar.Parent           = frame

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.FillDirection  = Enum.FillDirection.Horizontal
	tabLayout.Padding        = UDim.new(0,0)
	tabLayout.SortOrder      = Enum.SortOrder.LayoutOrder
	tabLayout.Parent         = tabBar

	-- UNDERLINE indicator
	local underline = Instance.new("Frame")
	underline.Size             = UDim2.new(0,0,0,2)
	underline.Position         = UDim2.new(0,0,1,-2)
	underline.BackgroundColor3 = Color3.fromRGB(255,255,255)
	underline.BorderSizePixel  = 0
	underline.ZIndex           = 13
	underline.Parent           = tabBar

	-- SCROLL
	local scroll = Instance.new("ScrollingFrame")
	scroll.Size                = UDim2.new(1,0,1,-72)
	scroll.Position            = UDim2.new(0,0,0,72)
	scroll.BackgroundTransparency = 1
	scroll.ScrollBarThickness  = 3
	scroll.CanvasSize          = UDim2.new(0,0,0,0)
	scroll.ZIndex              = 11
	scroll.Parent              = frame

	local layout = Instance.new("UIListLayout")
	layout.Padding   = UDim.new(0,5)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent    = scroll

	local pad = Instance.new("UIPadding")
	pad.PaddingTop    = UDim.new(0,5)
	pad.PaddingBottom = UDim.new(0,5)
	pad.PaddingLeft   = UDim.new(0,6)
	pad.PaddingRight  = UDim.new(0,6)
	pad.Parent        = scroll

	local collapsed = false
	local currentHeight = 100
	local function updateCanvas()
		task.defer(function()
			scroll.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 10)
			if not collapsed then
				currentHeight = math.clamp(layout.AbsoluteContentSize.Y + 82, 120, 460)
				frame.Size = UDim2.new(0, WIN_W, 0, currentHeight)
			end
		end)
	end
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

	-- COLLAPSE with animation
	colBtn.MouseButton1Click:Connect(function()
		collapsed = not collapsed
		if collapsed then
			TweenService:Create(colBtn, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Rotation = -90}):Play()
			task.spawn(function()
				task.wait(0.05)
				colBtn.Text = ">"
			end)
			TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{Size = UDim2.new(0,WIN_W,0,40)}):Play()
		else
			TweenService:Create(colBtn, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Rotation = 0}):Play()
			task.spawn(function()
				task.wait(0.05)
				colBtn.Text = "v"
			end)
			TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = UDim2.new(0,WIN_W,0, currentHeight)
			}):Play()
		end
	end)

	-- DRAG
	local dragging  = false
	local dragStart = nil
	local startPos  = nil

	titleBar.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = i.Position
			startPos = frame.Position
		end
	end)
	titleBar.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if not dragging then return end
		if i.UserInputType == Enum.UserInputType.MouseMovement
		or i.UserInputType == Enum.UserInputType.Touch then
			local sc    = workspace.CurrentCamera.ViewportSize
			local delta = i.Position - dragStart
			local newX  = math.clamp(startPos.X.Offset + delta.X, 0, math.max(0, sc.X - frame.AbsoluteSize.X))
			local newY  = math.clamp(startPos.Y.Offset + delta.Y, 0, math.max(0, sc.Y - frame.AbsoluteSize.Y))
			frame.Position = UDim2.new(0, newX, 0, newY)
		end
	end)

	-- ANTI OUT OF SCREEN
	RunService.RenderStepped:Connect(function()
		if not frame or not frame.Parent then return end
		local sc  = workspace.CurrentCamera.ViewportSize
		local pos = frame.Position
		local x   = math.clamp(pos.X.Offset, 0, math.max(0, sc.X - frame.AbsoluteSize.X))
		local y   = math.clamp(pos.Y.Offset, 0, math.max(0, sc.Y - frame.AbsoluteSize.Y))
		if x ~= pos.X.Offset or y ~= pos.Y.Offset then
			frame.Position = UDim2.new(0, x, 0, y)
		end
	end)

	if _loaded then
		frame.Visible = true
	else
		_pendingShow = function() frame.Visible = true end
	end

	local Win         = {}
	local _tabs       = {}
	local _activeTab  = nil
	local _tabCount   = 0

	local function switchTab(tabData)
		-- hide all content
		for _, t in ipairs(_tabs) do
			t.content.Visible = false
			t.btn.TextColor3 = Color3.fromRGB(150,150,150)
		end
		-- show selected
		tabData.content.Visible = true
		tabData.btn.TextColor3 = Color3.fromRGB(255,255,255)
		_activeTab = tabData

		-- move underline
		local btnAbsX = tabData.btn.AbsolutePosition.X - tabBar.AbsolutePosition.X
		local btnAbsW = tabData.btn.AbsoluteSize.X
		TweenService:Create(underline, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			Position = UDim2.new(0, btnAbsX, 1, -2),
			Size     = UDim2.new(0, btnAbsW, 0, 2)
		}):Play()

		updateCanvas()
	end

	function Win:CreateFolder(folderName)
		_tabCount += 1

		-- TAB BUTTON
		local tabW = WIN_W / math.max(_tabCount, 1)

		local btn = Instance.new("TextButton")
		btn.Size             = UDim2.new(0, tabW, 1, 0)
		btn.BackgroundTransparency = 1
		btn.Text             = folderName or "Tab"
		btn.Font             = Enum.Font.GothamBold
		btn.TextSize         = 12
		btn.TextColor3       = Color3.fromRGB(150,150,150)
		btn.ZIndex           = 12
		btn.LayoutOrder      = _tabCount
		btn.Parent           = tabBar

		-- CONTENT FRAME
		local contentFrame = Instance.new("Frame")
		contentFrame.Size             = UDim2.new(1,0,1,0)
		contentFrame.BackgroundTransparency = 1
		contentFrame.Visible          = false
		contentFrame.ZIndex           = 11
		contentFrame.Parent           = scroll

		local cLayout = Instance.new("UIListLayout")
		cLayout.Padding   = UDim.new(0,5)
		cLayout.SortOrder = Enum.SortOrder.LayoutOrder
		cLayout.Parent    = contentFrame

		local tabData = { btn = btn, content = contentFrame, name = folderName }
		table.insert(_tabs, tabData)

		-- resize all tab buttons evenly
		for _, t in ipairs(_tabs) do
			t.btn.Size = UDim2.new(0, WIN_W / #_tabs, 1, 0)
		end

		-- auto select first tab
		if #_tabs == 1 then
			switchTab(tabData)
		end

		btn.MouseButton1Click:Connect(function()
			switchTab(tabData)
		end)

		local Folder  = {}
		local _fOrder = 0
		local function fnxt() _fOrder += 1; return _fOrder end

		local function fUpdateCanvas()
			task.defer(function()
				-- update scroll canvas based on active tab
				if _activeTab and _activeTab.content == contentFrame then
					local cSize = cLayout.AbsoluteContentSize.Y
					scroll.CanvasSize = UDim2.new(0,0,0, cSize + 10)
					if not collapsed then
						currentHeight = math.clamp(cSize + 82, 120, 460)
						frame.Size = UDim2.new(0, WIN_W, 0, currentHeight)
					end
				end
			end)
		end
		cLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(fUpdateCanvas)

		function Folder:Button(text, callback)
			local btn2 = Instance.new("TextButton")
			btn2.Size             = UDim2.new(1,0,0,36)
			btn2.Text             = text or "Button"
			btn2.BackgroundColor3 = Color3.fromRGB(20,20,20)
			btn2.TextColor3       = Color3.fromRGB(255,255,255)
			btn2.Font             = Enum.Font.GothamBold
			btn2.TextSize         = 13
			btn2.LayoutOrder      = fnxt()
			btn2.TextXAlignment   = Enum.TextXAlignment.Left
			btn2.ZIndex           = 12
			btn2.Parent           = contentFrame
			_style(btn2)
			local bp = Instance.new("UIPadding")
			bp.PaddingLeft = UDim.new(0,10); bp.PaddingRight = UDim.new(0,10); bp.Parent = btn2
			btn2.MouseButton1Click:Connect(function()
				TweenService:Create(btn2, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(50,50,50)}):Play()
				task.wait(0.1)
				TweenService:Create(btn2, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(20,20,20)}):Play()
				if callback then pcall(callback) end
			end)
			fUpdateCanvas()
			return btn2
		end

		function Folder:Toggle(text, default, callback)
			local state = default or false
			local row = Instance.new("TextButton")
			row.Size             = UDim2.new(1,0,0,36)
			row.BackgroundColor3 = Color3.fromRGB(20,20,20)
			row.Text             = ""
			row.LayoutOrder      = fnxt()
			row.ZIndex           = 12
			row.Parent           = contentFrame
			_style(row)
			local lbl = Instance.new("TextLabel")
			lbl.Size               = UDim2.new(1,-50,1,0)
			lbl.Position           = UDim2.new(0,10,0,0)
			lbl.BackgroundTransparency = 1
			lbl.Text               = text or "Toggle"
			lbl.Font               = Enum.Font.GothamBold
			lbl.TextSize           = 13
			lbl.TextColor3         = Color3.fromRGB(255,255,255)
			lbl.TextXAlignment     = Enum.TextXAlignment.Left
			lbl.ZIndex             = 13
			lbl.Parent             = row
			local box = Instance.new("Frame")
			box.Size             = UDim2.new(0,22,0,22)
			box.Position         = UDim2.new(1,-32,0.5,-11)
			box.BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,40)
			box.ZIndex           = 13
			box.Parent           = row
			Instance.new("UICorner", box)
			row.MouseButton1Click:Connect(function()
				state = not state
				box.BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,40)
				if callback then pcall(callback, state) end
			end)
			fUpdateCanvas()
			local T = {}
			function T:Set(v) state = v; box.BackgroundColor3 = v and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,40) end
			function T:Get() return state end
			return T
		end

		function Folder:Slider(text, min, max, default, callback)
			min = min or 0; max = max or 100
			local val = math.clamp(default or min, min, max)
			local cont = Instance.new("Frame")
			cont.Size             = UDim2.new(1,0,0,62)
			cont.BackgroundColor3 = Color3.fromRGB(20,20,20)
			cont.LayoutOrder      = fnxt()
			cont.ZIndex           = 12
			cont.Parent           = contentFrame
			_style(cont)
			local tLbl = Instance.new("TextLabel")
			tLbl.Size               = UDim2.new(0.6,0,0,20)
			tLbl.Position           = UDim2.new(0,10,0,4)
			tLbl.Text               = text or "Slider"
			tLbl.Font               = Enum.Font.GothamBold
			tLbl.TextSize           = 13
			tLbl.TextXAlignment     = Enum.TextXAlignment.Left
			tLbl.TextColor3         = Color3.fromRGB(255,255,255)
			tLbl.BackgroundTransparency = 1
			tLbl.ZIndex             = 13
			tLbl.Parent             = cont
			local numBox = Instance.new("Frame")
			numBox.Size             = UDim2.new(0.15,0,0,22)
			numBox.Position         = UDim2.new(0.84,0,0,4)
			numBox.BackgroundColor3 = Color3.fromRGB(35,35,35)
			numBox.BorderSizePixel  = 0
			numBox.ZIndex           = 13
			numBox.Parent           = cont
			Instance.new("UICorner", numBox)
			local valTxt = Instance.new("TextBox")
			valTxt.Size               = UDim2.new(1,0,1,0)
			valTxt.BackgroundTransparency = 1
			valTxt.Text               = tostring(val)
			valTxt.Font               = Enum.Font.GothamBold
			valTxt.TextSize           = 12
			valTxt.TextColor3         = Color3.fromRGB(255,255,255)
			valTxt.ClearTextOnFocus   = false
			valTxt.TextXAlignment     = Enum.TextXAlignment.Center
			valTxt.ZIndex             = 14
			valTxt.Parent             = numBox
			local bar = Instance.new("Frame")
			bar.Size             = UDim2.new(1,-20,0,8)
			bar.Position         = UDim2.new(0,10,0.65,0)
			bar.BackgroundColor3 = Color3.fromRGB(35,35,35)
			bar.ZIndex           = 13
			bar.Parent           = cont
			Instance.new("UICorner", bar)
			local ip = (val-min)/(max-min)
			local fill = Instance.new("Frame")
			fill.Size             = UDim2.new(ip,0,1,0)
			fill.BackgroundColor3 = Color3.fromRGB(255,255,255)
			fill.ZIndex           = 14
			fill.Parent           = bar
			Instance.new("UICorner", fill)
			local knob = Instance.new("Frame")
			knob.Size             = UDim2.new(0,16,0,16)
			knob.AnchorPoint      = Vector2.new(0.5,0.5)
			knob.Position         = UDim2.new(ip,0,0.5,0)
			knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
			knob.ZIndex           = 15
			knob.Parent           = bar
			Instance.new("UICorner", knob)
			local sliderDrag = false
			local function setPos(pos)
				pos = math.clamp(pos,0,1)
				fill.Size     = UDim2.new(pos,0,1,0)
				knob.Position = UDim2.new(pos,0,0.5,0)
				val           = math.floor(min + pos*(max-min))
				valTxt.Text   = tostring(val)
				if callback then pcall(callback, val) end
			end
			bar.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					sliderDrag = true
					setPos((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
				end
			end)
			UIS.InputChanged:Connect(function(i)
				if sliderDrag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
					setPos((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
				end
			end)
			UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					sliderDrag = false
				end
			end)
			valTxt.FocusLost:Connect(function(enter)
				if enter then
					local v = tonumber(valTxt.Text)
					if v then
						val = math.clamp(v,min,max)
						local p = (val-min)/(max-min)
						fill.Size = UDim2.new(p,0,1,0)
						knob.Position = UDim2.new(p,0,0.5,0)
						valTxt.Text = tostring(val)
						if callback then pcall(callback, val) end
					else valTxt.Text = tostring(val) end
				end
			end)
			fUpdateCanvas()
			local S = {}
			function S:Set(v)
				val = math.clamp(v,min,max)
				local p = (val-min)/(max-min)
				fill.Size = UDim2.new(p,0,1,0)
				knob.Position = UDim2.new(p,0,0.5,0)
				valTxt.Text = tostring(val)
			end
			function S:Get() return val end
			return S
		end

