				TweenService:Create(dropFrame, TweenInfo.new(0.25), {Size = UDim2.new(1,0,0,h)}):Play()
				task.delay(0.26, fUpdateCanvas)
			end)
			fUpdateCanvas()
			local D = {}
			function D:Get() return selected end
			function D:Set(v) selected = v; selLbl.Text = v end
			return D
		end

		function Folder:ClipboardButton(text, clipText)
			local btn2 = Instance.new("TextButton")
			btn2.Size             = UDim2.new(1,0,0,36)
			btn2.Text             = text or "Copy"
			btn2.BackgroundColor3 = Color3.fromRGB(20,20,20)
			btn2.TextColor3       = Color3.fromRGB(255,255,255)
			btn2.Font             = Enum.Font.GothamBold
			btn2.TextSize         = 13
			btn2.LayoutOrder      = fnxt()
			btn2.TextXAlignment   = Enum.TextXAlignment.Left
			btn2.ZIndex           = 12
			btn2.Parent           = contentFrame
			_style(btn2)
			local bp = Instance.new("UIPadding")
			bp.PaddingLeft = UDim.new(0,10); bp.Parent = btn2
			btn2.MouseButton1Click:Connect(function()
				TweenService:Create(btn2, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(50,50,50)}):Play()
				task.wait(0.1)
				TweenService:Create(btn2, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(20,20,20)}):Play()
				if clipText then pcall(function() setclipboard(clipText) end) end
			end)
			fUpdateCanvas()
			return btn2
		end

		function Folder:Section(text)
			local sec = Instance.new("Frame")
			sec.Size                  = UDim2.new(1,0,0,24)
			sec.BackgroundTransparency = 1
			sec.LayoutOrder           = fnxt()
			sec.Parent                = contentFrame
			local lineL = Instance.new("Frame")
			lineL.Size             = UDim2.new(0.25,0,0,1)
			lineL.Position         = UDim2.new(0,0,0.5,0)
			lineL.BackgroundColor3 = Color3.fromRGB(60,60,60)
			lineL.BorderSizePixel  = 0
			lineL.Parent           = sec
			local lineR = Instance.new("Frame")
			lineR.Size             = UDim2.new(0.25,0,0,1)
			lineR.Position         = UDim2.new(0.75,0,0.5,0)
			lineR.BackgroundColor3 = Color3.fromRGB(60,60,60)
			lineR.BorderSizePixel  = 0
			lineR.Parent           = sec
			local sLbl = Instance.new("TextLabel")
			sLbl.Size                  = UDim2.new(0.5,0,1,0)
			sLbl.Position              = UDim2.new(0.25,0,0,0)
			sLbl.BackgroundTransparency = 1
			sLbl.Text                  = text or ""
			sLbl.TextColor3            = Color3.fromRGB(120,120,120)
			sLbl.Font                  = Enum.Font.GothamBold
			sLbl.TextSize              = 12
			sLbl.Parent                = sec
			fUpdateCanvas()
		end

		return Folder
	end

	return Win
end

function Lib:Start()
	_loaded = true
	if _pendingShow then _pendingShow() end
end

return Lib
