return function()

local UIS = game:GetService("UserInputService")

local UILib = {}

function UILib:CreateWindow(title)

    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)

    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 350, 0, 400)
    Main.Position = UDim2.new(0.5,-175,0.5,-200)
    Main.BackgroundColor3 = Color3.fromRGB(15,15,15)
    Main.BorderSizePixel = 0

    -- STROKE (BLACK/WHITE FADED)
    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Color = Color3.fromRGB(200,200,200)
    Stroke.Transparency = 0.5

    -- DRAGGABLE
    local dragging, dragInput, dragStart, startPos

    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)

    Main.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    -- TITLE
    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1,0,0,40)
    Title.Text = "Smileyy Hub | "..title
    Title.TextColor3 = Color3.fromRGB(255,255,255)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16

    -- OPEN CLOSE
    local ToggleBtn = Instance.new("TextButton", Main)
    ToggleBtn.Size = UDim2.new(0,40,0,40)
    ToggleBtn.Position = UDim2.new(1,-40,0,0)
    ToggleBtn.Text = "v"
    ToggleBtn.BackgroundTransparency = 1
    ToggleBtn.TextColor3 = Color3.new(1,1,1)

    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1,0,1,-40)
    Content.Position = UDim2.new(0,0,0,40)
    Content.BackgroundTransparency = 1

    local Layout = Instance.new("UIListLayout", Content)
    Layout.Padding = UDim.new(0,5)

    local opened = true

    ToggleBtn.MouseButton1Click:Connect(function()
        opened = not opened
        Content.Visible = opened
        ToggleBtn.Text = opened and "v" or ">"
    end)

    local Window = {}

    -- FOLDER SYSTEM
    function Window:Folder(name)
        local FolderBtn = Instance.new("TextButton", Content)
        FolderBtn.Size = UDim2.new(1,-10,0,35)
        FolderBtn.Text = "v "..name
        FolderBtn.BackgroundColor3 = Color3.fromRGB(25,25,25)
        FolderBtn.TextColor3 = Color3.new(1,1,1)

        local FolderContent = Instance.new("Frame", Content)
        FolderContent.Size = UDim2.new(1,-10,0,0)
        FolderContent.ClipsDescendants = true
        FolderContent.BackgroundTransparency = 1

        local Layout2 = Instance.new("UIListLayout", FolderContent)
        Layout2.Padding = UDim.new(0,5)

        local open = true

        FolderBtn.MouseButton1Click:Connect(function()
            open = not open
            FolderBtn.Text = (open and "v " or "> ")..name
            FolderContent.Size = open and UDim2.new(1,-10,0,Layout2.AbsoluteContentSize.Y) or UDim2.new(1,-10,0,0)
        end)

        local Folder = {}

        -- BUTTON
        function Folder:Button(text, callback)
            local Btn = Instance.new("TextButton", FolderContent)
            Btn.Size = UDim2.new(1,0,0,35)
            Btn.Text = text
            Btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
            Btn.TextColor3 = Color3.new(1,1,1)

            Btn.MouseButton1Click:Connect(callback)
        end

        -- TOGGLE
        function Folder:Toggle(text, default, callback)
            local state = default or false

            local Btn = Instance.new("TextButton", FolderContent)
            Btn.Size = UDim2.new(1,0,0,35)
            Btn.Text = text.." : "..tostring(state)
            Btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
            Btn.TextColor3 = Color3.new(1,1,1)

            Btn.MouseButton1Click:Connect(function()
                state = not state
                Btn.Text = text.." : "..tostring(state)
                callback(state)
            end)
        end

        -- SLIDER
        function Folder:Slider(text, min, max, callback)
            local val = min

            local Frame = Instance.new("Frame", FolderContent)
            Frame.Size = UDim2.new(1,0,0,45)
            Frame.BackgroundTransparency = 1

            local Label = Instance.new("TextLabel", Frame)
            Label.Size = UDim2.new(1,0,0,20)
            Label.Text = text.." : "..val
            Label.TextColor3 = Color3.new(1,1,1)
            Label.BackgroundTransparency = 1

            local Bar = Instance.new("Frame", Frame)
            Bar.Size = UDim2.new(1,0,0,10)
            Bar.Position = UDim2.new(0,0,0,25)
            Bar.BackgroundColor3 = Color3.fromRGB(40,40,40)

            local Fill = Instance.new("Frame", Bar)
            Fill.Size = UDim2.new(0,0,1,0)
            Fill.BackgroundColor3 = Color3.fromRGB(255,255,255)

            Bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local move
                    move = UIS.InputChanged:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseMovement then
                            local pos = math.clamp((i.Position.X - Bar.AbsolutePosition.X)/Bar.AbsoluteSize.X,0,1)
                            Fill.Size = UDim2.new(pos,0,1,0)
                            val = math.floor(min + (max-min)*pos)
                            Label.Text = text.." : "..val
                            callback(val)
                        end
                    end)
                end
            end)
        end

        -- DROPDOWN (kept darker)
        function Folder:Dropdown(text, list, callback)
            local Btn = Instance.new("TextButton", FolderContent)
            Btn.Size = UDim2.new(1,0,0,35)
            Btn.Text = text
            Btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
            Btn.TextColor3 = Color3.new(1,1,1)

            local Drop = Instance.new("Frame", FolderContent)
            Drop.Size = UDim2.new(1,0,0,0)
            Drop.ClipsDescendants = true
            Drop.BackgroundColor3 = Color3.fromRGB(20,20,20)

            local Layout3 = Instance.new("UIListLayout", Drop)

            local open = false

            Btn.MouseButton1Click:Connect(function()
                open = not open
                Drop.Size = open and UDim2.new(1,0,0,#list*30) or UDim2.new(1,0,0,0)
            end)

            for _,v in pairs(list) do
                local Item = Instance.new("TextButton", Drop)
                Item.Size = UDim2.new(1,0,0,30)
                Item.Text = v
                Item.BackgroundColor3 = Color3.fromRGB(30,30,30)
                Item.TextColor3 = Color3.new(1,1,1)

                Item.MouseButton1Click:Connect(function()
                    callback(v)
                end)
            end
        end

        return Folder
    end

    -- CREDITS FOLDER (clipboard)
    function Window:Credits(text)
        local Btn = Instance.new("TextButton", Content)
        Btn.Size = UDim2.new(1,-10,0,35)
        Btn.Text = "Copy Credits"
        Btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        Btn.TextColor3 = Color3.new(1,1,1)

        Btn.MouseButton1Click:Connect(function()
            if setclipboard then
                setclipboard(text)
            end
        end)
    end

    return Window
end

return UILib

end
