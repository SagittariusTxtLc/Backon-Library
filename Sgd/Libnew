		-- TOGGLE (pill style like the image)
		function Folder:Toggle(text, default, callback)
			local state = default or false

			local row = Instance.new("Frame")
			row.Size             = UDim2.new(1,0,0,38)
			row.BackgroundColor3 = Color3.fromRGB(18,18,18)
			row.LayoutOrder      = fnxt()
			row.ZIndex           = 12
			row.Parent           = contentFrame
			_style(row)

			local lbl = Instance.new("TextLabel")
			lbl.Size               = UDim2.new(1,-55,1,0)
			lbl.Position           = UDim2.new(0,10,0,0)
			lbl.BackgroundTransparency = 1
			lbl.Text               = text or "Toggle"
			lbl.Font               = Enum.Font.GothamBold
			lbl.TextSize           = 13
			lbl.TextColor3         = Color3.fromRGB(255,255,255)
			lbl.TextXAlignment     = Enum.TextXAlignment.Left
			lbl.ZIndex             = 13
			lbl.Parent             = row

			-- PILL background
			local pill = Instance.new("TextButton")
			pill.Size             = UDim2.new(0,40,0,22)
			pill.Position         = UDim2.new(1,-48,0.5,-11)
			pill.BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,40)
			pill.Text             = ""
			pill.ZIndex           = 13
			pill.Parent           = row
			local pc = Instance.new("UICorner", pill)
			pc.CornerRadius = UDim.new(1,0)

			-- PILL circle
			local circle = Instance.new("Frame")
			circle.Size             = UDim2.new(0,16,0,16)
			circle.Position         = state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
			circle.BackgroundColor3 = Color3.fromRGB(255,255,255)
			circle.ZIndex           = 14
			circle.Parent           = pill
			local cc2 = Instance.new("UICorner", circle)
			cc2.CornerRadius = UDim.new(1,0)

			local function toggle()
				state = not state
				TweenService:Create(pill, TweenInfo.new(0.2), {
					BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,40)
				}):Play()
				TweenService:Create(circle, TweenInfo.new(0.2), {
					Position = state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
				}):Play()
				if callback then pcall(callback, state) end
			end

			row.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					toggle()
				end
			end)
			pill.MouseButton1Click:Connect(toggle)

			local T = {}
			function T:Set(v)
				state = v
				pill.BackgroundColor3 = v and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,40)
				circle.Position = v and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
			end
			function T:Get() return state end
			return T
		end

		-- SLIDER
		function Folder:Slider(text, min, max, default, callback)
			min = min or 0; max = max or 100
			local val = math.clamp(default or min, min, max)
			local cont = Instance.new("Frame")
			cont.Size             = UDim2.new(1,0,0,60)
			cont.BackgroundColor3 = Color3.fromRGB(18,18,18)
			cont.LayoutOrder      = fnxt()
			cont.ZIndex           = 12
			cont.Parent           = contentFrame
			_style(cont)
			local tLbl = Instance.new("TextLabel")
			tLbl.Size               = UDim2.new(0.6,0,0,20)
			tLbl.Position           = UDim2.new(0,10,0,4)
			tLbl.Text               = text or "Slider"
			tLbl.Font               = Enum.Font.GothamBold
			tLbl.TextSize           = 13
			tLbl.TextXAlignment     = Enum.TextXAlignment.Left
			tLbl.TextColor3         = Color3.fromRGB(255,255,255)
			tLbl.BackgroundTransparency = 1
			tLbl.ZIndex             = 13
			tLbl.Parent             = cont
			local numBox = Instance.new("Frame")
			numBox.Size             = UDim2.new(0.18,0,0,20)
			numBox.Position         = UDim2.new(0.82,0,0,4)
			numBox.BackgroundColor3 = Color3.fromRGB(30,30,30)
			numBox.BorderSizePixel  = 0
			numBox.ZIndex           = 13
			numBox.Parent           = cont
			Instance.new("UICorner", numBox)
			local valTxt = Instance.new("TextBox")
			valTxt.Size               = UDim2.new(1,0,1,0)
			valTxt.BackgroundTransparency = 1
			valTxt.Text               = tostring(val)
			valTxt.Font               = Enum.Font.GothamBold
			valTxt.TextSize           = 12
			valTxt.TextColor3         = Color3.fromRGB(255,255,255)
			valTxt.ClearTextOnFocus   = false
			valTxt.TextXAlignment     = Enum.TextXAlignment.Center
			valTxt.ZIndex             = 14
			valTxt.Parent             = numBox
			local bar = Instance.new("Frame")
			bar.Size             = UDim2.new(1,-20,0,7)
			bar.Position         = UDim2.new(0,10,0.68,0)
			bar.BackgroundColor3 = Color3.fromRGB(35,35,35)
			bar.ZIndex           = 13
			bar.Parent           = cont
			Instance.new("UICorner", bar)
			local ip = (val-min)/(max-min)
			local fill = Instance.new("Frame")
			fill.Size             = UDim2.new(ip,0,1,0)
			fill.BackgroundColor3 = Color3.fromRGB(255,255,255)
			fill.ZIndex           = 14
			fill.Parent           = bar
			Instance.new("UICorner", fill)
			local knob = Instance.new("Frame")
			knob.Size             = UDim2.new(0,14,0,14)
			knob.AnchorPoint      = Vector2.new(0.5,0.5)
			knob.Position         = UDim2.new(ip,0,0.5,0)
			knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
			knob.ZIndex           = 15
			knob.Parent           = bar
			Instance.new("UICorner", knob)
			local sliderDrag = false
			local function setPos(pos)
				pos = math.clamp(pos,0,1)
				fill.Size     = UDim2.new(pos,0,1,0)
				knob.Position = UDim2.new(pos,0,0.5,0)
				val           = math.floor(min + pos*(max-min))
				valTxt.Text   = tostring(val)
				if callback then pcall(callback, val) end
			end
			bar.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					sliderDrag = true
					setPos((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
				end
			end)
			UIS.InputChanged:Connect(function(i)
				if sliderDrag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
					setPos((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
				end
			end)
			UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					sliderDrag = false
				end
			end)
			valTxt.FocusLost:Connect(function(enter)
				if enter then
					local v = tonumber(valTxt.Text)
					if v then
						val = math.clamp(v,min,max)
						local p = (val-min)/(max-min)
						fill.Size = UDim2.new(p,0,1,0)
						knob.Position = UDim2.new(p,0,0.5,0)
						valTxt.Text = tostring(val)
						if callback then pcall(callback, val) end
					else valTxt.Text = tostring(val) end
				end
			end)
			local S = {}
			function S:Set(v)
				val = math.clamp(v,min,max)
				local p = (val-min)/(max-min)
				fill.Size = UDim2.new(p,0,1,0)
				knob.Position = UDim2.new(p,0,0.5,0)
				valTxt.Text = tostring(val)
			end
			function S:Get() return val end
			return S
		end

