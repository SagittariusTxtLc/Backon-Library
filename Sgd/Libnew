	colBtn.BackgroundColor3   = Color3.fromRGB(25,25,25)
	colBtn.Font               = Enum.Font.GothamBold
	colBtn.TextSize           = 13
	colBtn.TextColor3         = Color3.fromRGB(255,255,255)
